{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false
  },
  "include": [
    "src/extension.ts",
    "src/IpcValidator.ts",
    "src/types.ts",
    "src/backend/**/*.ts"
  ],
  "exclude": [
    "src/webview/**/*",
    "dist",
    "node_modules"
  ]
}
